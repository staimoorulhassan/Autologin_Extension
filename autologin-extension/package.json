{
  "name": "autologin-extension",
  "version": "1.0.0",
  "description": "Firefox extension for automated login across multiple websites",
  "main": "src/background/worker.ts",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "dev": "webpack --mode development --watch",
    "build": "webpack --mode production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern='\\.test\\.ts$' --testNamePattern='^(?!.*integration|.*e2e)'",
    "test:integration": "jest --testPathPattern='\\.integration\\.test\\.ts$'",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "web-ext": "web-ext",
    "web-ext:run": "web-ext run --source-dir ./dist",
    "web-ext:sign": "web-ext sign --source-dir ./dist"
  },
  "dependencies": {
    "dexie": "^3.2.4",
    "html2canvas": "^1.4.1",
    "puppeteer-core": "^21.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tweetnacl": "^1.0.3",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.42",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "eslint": "^8.40.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "web-ext": "^7.6.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
